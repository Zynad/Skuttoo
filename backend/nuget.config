<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Backend-scoped NuGet config. Public packages only (CLAUDE.md golden rule #5).
    We <clear/> any inherited sources (e.g. private Triggerbee feed) so this
    self-contained backend restores solely from nuget.org.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
