# Frontend environment variables.
# Only VITE_* values that are SAFE TO BE PUBLIC belong here — everything in this
# file ends up in the client bundle of this PUBLIC repo. NEVER put the Azure
# Speech key (or any secret) here; TTS audio is generated server-side.

# Base path for the JSON API. Defaults to "/api" (served by the .NET app / dev proxy).
VITE_API_BASE_URL=/api
