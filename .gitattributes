# Normalize line endings: LF in the repo (CI builds on Linux), checked out natively.
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.mp3 binary
*.db binary
