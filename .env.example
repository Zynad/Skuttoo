# Skuttoo — environment template. Copy to `.env` (gitignored) for local overrides.
# PUBLIC REPO: never put real secrets in committed files. This file documents what is needed;
# real values go in `dotnet user-secrets` (local) or Azure App Service settings (prod).

# ── Frontend (Vite) — PUBLIC values only (these are bundled into the client) ───────────────
# Base path/URL for the API. "/api" = same-origin (the backend serves the built frontend).
VITE_API_BASE_URL=/api

# ── Backend — DO NOT put real secret values here ──────────────────────────────────────────
# Local:  cd backend/src/Skuttoo.Api && dotnet user-secrets set "Speech:Key" "<key>"
# Prod:   set as Azure App Service application settings (double underscore = nested config):
#           Speech__Key, Speech__Region, ConnectionStrings__Default
#
# Speech__Key=              # Azure Cognitive Services Speech key — SERVER-SIDE ONLY, never in the frontend
# Speech__Region=           # e.g. westeurope
# ConnectionStrings__Default=Data Source=/home/data/app.db   # persistent path on App Service
